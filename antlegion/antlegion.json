{
  "bus": {
    "url": "http://localhost:28080",
    "name": "antlegion-agent",
    "description": "Default antlegion agent",
    "filter": {
      "capabilityOffer": [],
      "domainInterests": [],
      "factTypePatterns": ["*"],
      "priorityRange": [0, 7],
      "modes": ["exclusive", "broadcast"]
    }
  },
  "provider": {
    "type": "anthropic",
    "model": "claude-sonnet-4-6-20250514",
    "apiKey": "env:ANTHROPIC_API_KEY"
  },
  "workspace": "./workspace",
  "agent": {
    "loopInterval": 1000,
    "heartbeatInterval": 30000,
    "eventQueueCapacity": 100,
    "maxToolRounds": 20,
    "sessionKeepTurns": 3
  }
}
