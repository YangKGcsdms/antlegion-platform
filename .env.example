# ══════════════════════════════════════════════════════════════════
# Legion Bus 配置
# ══════════════════════════════════════════════════════════════════
ANTLEGION_BUS_SECRET=change-this-to-any-random-string

# ══════════════════════════════════════════════════════════════════
# LLM 配置 — 选择以下两种方式之一，注释掉另一种
# ══════════════════════════════════════════════════════════════════

# ── 方式A：Anthropic Claude ──────────────────────────────────────
# LLM_PROVIDER_TYPE=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# LLM_MODEL=claude-sonnet-4-6-20250514

# ── 方式B：OpenAI 兼容接口（SiliconFlow / OpenRouter 等）─────────
LLM_PROVIDER_TYPE=openai-compatible
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
